# ============================================
# MatchIQ — Environment Variables
# Copy to .env.local and fill in values
# ============================================

# Google Sheets API Key (read-only access to betting data)
VITE_GOOGLE_SHEETS_API_KEY=

# Gemini AI API Key (betting recommendations)
VITE_GEMINI_API_KEY=

# OpenRouter API Key (alternative AI provider)
VITE_OPENROUTER_API_KEY=

# Supabase (for future auth migration)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Telegram Bot
VITE_TELEGRAM_BOT_TOKEN=

# CS2 Match API
VITE_CS_API_URL=https://api.cstest.pp.ua

# DeepSeek AI (AI recommendations — currently used)
VITE_DEEPSEEK_API_KEY=

# Error Report URL (optional — send client errors to monitoring)
VITE_ERROR_REPORT_URL=