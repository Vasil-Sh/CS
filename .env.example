# ============================================
# MatchIQ — Environment Variables
# Copy to .env.local and fill in values
# ============================================

# ── Backend API ──
VITE_API_URL=http://localhost:3001/api

# ── Google Sheets API Key (legacy — now handled by backend) ──
# VITE_GOOGLE_SHEETS_API_KEY=

# ── Gemini AI API Key (legacy — now handled by backend) ──
# VITE_GEMINI_API_KEY=

# ── OpenRouter API Key (legacy — now handled by backend) ──
# VITE_OPENROUTER_API_KEY=

# ── Supabase (for future auth migration) ──
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# ── Telegram Bot (legacy — now webhook goes to backend) ──
# VITE_TELEGRAM_BOT_TOKEN=

# ── CS2 Match API (public, still used by frontend) ──
VITE_CS_API_URL=https://api.cstest.pp.ua

# ── DeepSeek AI (legacy — API key now on backend only) ──
# VITE_DEEPSEEK_API_KEY=

# ── Error Report URL (optional) ──
# VITE_ERROR_REPORT_URL=